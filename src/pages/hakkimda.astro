---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Hakkımda"
  description="Prof. Dr. Elif Akkaş Yılmaz — Kadın Hastalıkları ve Doğum Profesörü. Biyoeşdeğer hormon replasman tedavisi (BHRT), biyoidentikal hormon tedavisi, perimenopoz ve menopoz yönetimi, hormonal dengesizlik ve kadın sağlığı alanlarında uzman hekim."
>

  <!-- ── PAGE HEADER ──────────────────────────────────────────── -->
  <div class="bg-forest text-ivory py-16">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <p class="font-sans text-xs uppercase tracking-[0.25em] text-gold mb-3">Hakkımda</p>
      <h1 class="font-serif text-4xl font-bold">Prof. Dr. Elif Akkaş Yılmaz</h1>
      <div class="w-16 h-px bg-gold mx-auto mt-6"></div>
    </div>
  </div>

  <!-- ── MAIN CONTENT ─────────────────────────────────────────── -->
  <div class="section max-w-4xl">

    <!-- Photo + intro -->
    <div class="flex flex-col md:flex-row gap-12 items-start mb-16">

      <!-- Photo -->
      <div class="flex-shrink-0 mx-auto md:mx-0">
        <div class="w-56 h-56 rounded-full overflow-hidden border-4 border-sage/30 bg-sage/10 flex items-center justify-center">
          <img src="/images/elif-akkasyon.jpg" alt="Prof. Dr. Elif Akkaş Yılmaz — Kadın Hastalıkları ve Doğum Profesörü" class="w-full h-full object-cover" />
          <span class="font-serif text-6xl text-sage/40">E</span>
        </div>
      </div>

      <!-- Bio -->
      <div class="flex-1">
        <h2 class="font-serif text-2xl text-forest font-semibold mb-1">
          Prof. Dr. Elif Akkaş Yılmaz
        </h2>
        <p class="font-sans text-sm text-gold uppercase tracking-widest mb-4">
          Kadın Hastalıkları ve Doğum Profesörü
        </p>
        <div class="divider mx-0"></div>
        <p class="font-sans text-warm leading-relaxed mt-6">
          Tıp hayatım boyunca kadın sağlığına olan ilgim hep ön planda oldu ve kadın sağlığını sadece doğum ve üreme konularıyla sınırlı kalmadan, yaşamın her evresinde bütüncül bir perspektifle ele almayı hedefledim. Kadın doğum uzmanı olarak çalıştığım ilk yıllarda, hormonların sağlığımız üzerindeki önemi her geçen gün beni daha çok etkiledi ve bu alana yönelmemi sağladı.
        </p>
        <p class="font-sans text-warm leading-relaxed mt-4">
          Uzun yıllardır hormon düzensizlikleri ile yakından ilgileniyorum; özellikle yurt dışında alanında deneyimli uzmanlardan aldığım eğitimlerle hem üreme çağında görülen hormonal sorunlar (adet düzensizlikleri, polikistik over gibi metabolik bozukluklar, tiroid ya da böbrek üstü bezi hastalıkları) hem de perimenopoz ve menopoz döneminde hormonal değişimlerin yönetimi ve biyoeşdeğer hormon replasman tedavisi (BHRT) konularında uzmanlaştım.
        </p>
        <p class="font-sans text-warm leading-relaxed mt-4">
          Amacım, her kadının bedenini daha iyi anlaması, şikayetlerini görmezden gelmemesi ve sağlığıyla ilgili bilinçli seçimler yapabilmesine yardımcı olmak ve kadınların hayatlarının her evresinde yaşam kalitesini koruyacak ve iyileştirecek bilinci kazanmalarını sağlamaktır.
        </p>
      </div>
    </div>

    <!-- Credentials grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

      <!-- Eğitim -->
      <div>
        <h3 class="font-serif text-xl text-forest font-semibold mb-4">Eğitim</h3>
        <div class="w-10 h-px bg-gold mb-6"></div>
        <ul class="space-y-4 font-sans text-sm text-warm">
          <li class="flex gap-3">
            <span class="text-gold font-semibold flex-shrink-0">——</span>
            <div>
              <p class="font-medium text-forest">Lise</p>
              <p class="text-warm/60">TED Ankara Koleji · 1991</p>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-gold font-semibold flex-shrink-0">——</span>
            <div>
              <p class="font-medium text-forest">Tıp Fakültesi</p>
              <p class="text-warm/60">Gazi Üniversitesi Tıp Fakültesi · 1997</p>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-gold font-semibold flex-shrink-0">——</span>
            <div>
              <p class="font-medium text-forest">Kadın Hastalıkları ve Doğum Uzmanlığı</p>
              <p class="text-warm/60">S.B. Ankara Eğitim ve Araştırma Hastanesi · 2004</p>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-gold font-semibold flex-shrink-0">——</span>
            <div>
              <p class="font-medium text-forest">Halk Sağlığı Doktora</p>
              <p class="text-warm/60">Gazi Üniversitesi Tıp Fakültesi · 2019</p>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-gold font-semibold flex-shrink-0">——</span>
            <div>
              <p class="font-medium text-forest">Profesörlük</p>
              <p class="text-warm/60">Sağlık Bilimleri Üniversitesi · 2024</p>
            </div>
          </li>
        </ul>
      </div>

      <!-- Uzmanlık Alanları -->
      <div>
        <h3 class="font-serif text-xl text-forest font-semibold mb-4">Uzmanlık Alanları</h3>
        <div class="w-10 h-px bg-gold mb-6"></div>
        <ul class="space-y-3 font-sans text-sm text-warm">
          {[
            'Biyoeşdeğer Hormon Replasman Tedavisi (BHRT)',
            'Perimenopoz ve Menopoz Yönetimi',
            'Kadın Sağlığı ve Sağlıklı Yaşlanma',
            'Adet Düzensizlikleri ve Metabolik Bozukluklar',
            'Hormonal Değerlendirme ve Kişiselleştirilmiş Tedaviler',
            'Kemik Sağlığını Koruma',
            'Kadın Cinsel Sağlığı',
          ].map((item) => (
            <li class="flex gap-3 items-start">
              <span class="text-sage mt-0.5">◆</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Görevler -->
      <div>
        <h3 class="font-serif text-xl text-forest font-semibold mb-4">Görevler</h3>
        <div class="w-10 h-px bg-gold mb-6"></div>
        <ul class="space-y-4 font-sans text-sm text-warm">
          <li class="flex gap-3">
            <span class="text-gold font-semibold flex-shrink-0">——</span>
            <div>
              <p class="font-medium text-forest">Klinik Şefi</p>
              <p class="text-warm/60">Ankara Atatürk Sanatoryum Eğitim ve Araştırma Hastanesi · 2024–2026</p>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-gold font-semibold flex-shrink-0">——</span>
            <div>
              <p class="font-medium text-forest">Uzman Hekim</p>
              <p class="text-warm/60">SBÜ Dr. Sami Ulus Kadın Doğum, Çocuk Sağlığı ve Hastalıkları Eğitim ve Araştırma Hastanesi · 2011–2023</p>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-gold font-semibold flex-shrink-0">——</span>
            <div>
              <p class="font-medium text-forest">Sağlık Bakanlığı Eğiticisi</p>
              <p class="text-warm/60">Üreme Sağlığı · Yenidoğan Canlandırma (NRP) · Anne Sütü ve Emzirme</p>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-gold font-semibold flex-shrink-0">——</span>
            <div>
              <p class="font-medium text-forest">Sağlık Bakanlığı Ulusal Değerlendirmeci</p>
              <p class="text-warm/60">Bebek Dostu Hastane · Doğuma Hazırlık Sınıfı Organizasyonu ve Yönetimi</p>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-gold font-semibold flex-shrink-0">——</span>
            <div>
              <p class="font-medium text-forest">Cinsel Terapist</p>
              <p class="text-warm/60">Cinsel Sağlık Enstitüsü Derneği · 2013</p>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="text-gold font-semibold flex-shrink-0">——</span>
            <div>
              <p class="font-medium text-forest">Hipnoterapist</p>
              <p class="text-warm/60">T.C. SB Sağlık Hizmetleri Genel Müdürlüğü · 2017</p>
            </div>
          </li>
        </ul>
      </div>

      <!-- Üyelikler -->
      <div>
        <h3 class="font-serif text-xl text-forest font-semibold mb-4">Üyelikler</h3>
        <div class="w-10 h-px bg-gold mb-6"></div>
        <ul class="space-y-3 font-sans text-sm text-warm">
          {[
            'Menopoz ve Üreme Sağlığı Derneği (MENÜDER) — Yönetim Kurulu Üyesi',
            'Uluslararası Jinekoloji ve Obstetri Derneği (UJOD) — Üye',
          ].map((item) => (
            <li class="flex gap-3 items-start">
              <span class="text-sage mt-0.5">◆</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- CTA -->
    <div class="mt-16 text-center border-t border-sage/20 pt-12">
      <p class="font-sans text-warm/70 mb-6">Sorularınız mı var? Bana ulaşın.</p>
      <a href="/iletisim" class="btn-primary">İletişime Geç</a>
    </div>

  </div>

</BaseLayout>
